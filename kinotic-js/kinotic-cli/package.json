{
  "name": "@kinotic-ai/kinotic-cli",
  "version": "1.0.1",
  "description": "Kinotic CLI provides the ability to interact with the Kinotic Server",
  "author": "Kinotic Developers",
  "bin": {
    "kinotic": "./bin/run.js"
  },
  "homepage": "https://kinotic-ai",
  "repository": "https://github.com/kinotic-ai/kinotic",
  "license": "Elastic License 2.0\"",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "/bin",
    "/dist",
    "/npm-shrinkwrap.json",
    "/oclif.manifest.json"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@kinotic-ai/core": "^1.0.7",
    "@kinotic-ai/idl": "^1.0.7",
    "@kinotic-ai/os-api": "^1.0.7",
    "@kinotic-ai/persistence": "^1.0.7",
    "@oclif/core": "^4.9.0",
    "@oclif/plugin-autocomplete": "^3.2.41",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-not-found": "^3.2.75",
    "@oclif/plugin-plugins": "^5.4.58",
    "@oclif/plugin-update": "^4.7.23",
    "@oclif/plugin-warn-if-update-available": "^3.1.55",
    "c12": "^3.3.3",
    "chalk": "^5.6.2",
    "glob": "^13.0.6",
    "graphql": "^16.13.1",
    "liquidjs": "^10.25.0",
    "open": "^11.0.0",
    "p-timeout": "^7.0.1",
    "radash": "^12.1.1",
    "reflect-metadata": "^0.2.2",
    "terminal-link": "^5.0.0",
    "ts-morph": "^27.0.2",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@oclif/test": "^4.1.16",
    "@types/chai": "^5",
    "@types/inquirer": "^9.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "chai": "^6",
    "eslint": "^10",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4.22.92",
    "shx": "^0.4.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "oclif": {
    "bin": "kinotic",
    "dirname": "kinotic",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins",
      "@oclif/plugin-update",
      "@oclif/plugin-not-found",
      "@oclif/plugin-warn-if-update-available",
      "@oclif/plugin-autocomplete"
    ],
    "topicSeparator": " ",
    "topics": {}
  },
  "scripts": {
    "build": "shx rm -rf dist && tsc -b && pnpm run copy-files",
    "lint": "eslint . --ext .ts --config .eslintrc",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "pnpm lint",
    "prepack": "pnpm build && oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md",
    "copy-files": "cp -r ./src/templates/  ./dist/templates/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "oclif"
  ],
  "types": "dist/index.d.ts"
}
