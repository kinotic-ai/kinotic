{
    "name": "@kinotic-ai/kinotic-cli",
    "version": "2.2.0",
    "description": "Kinotic CLI provides the ability to build, deploy, and manage Kinotic applications that run on the Kinotic OS.",
    "author": "Kinotic Developers",
    "bin": {
        "kinotic": "./bin/run.js"
    },
    "homepage": "https://kinotic-ai",
    "repository": "https://github.com/kinotic-ai/kinotic",
    "license": "Elastic License 2.0\"",
    "main": "dist/index.js",
    "type": "module",
    "files": [
        "/bin",
        "/dist",
        "/npm-shrinkwrap.json"
    ],
    "dependencies": {
        "@inquirer/prompts": "^8.3.2",
        "@kinotic-ai/core": "^1.1.1",
        "@kinotic-ai/idl": "^1.0.9",
        "@kinotic-ai/os-api": "^1.1.0",
        "@kinotic-ai/persistence": "^1.2.0",
        "@oclif/core": "^4.9.0",
        "c12": "^3.3.3",
        "chalk": "^5.6.2",
        "execa": "^9.6.1",
        "glob": "^13.0.6",
        "graphql": "^16.13.1",
        "liquidjs": "10.25.1",
        "open": "^11.0.0",
        "ora": "^9.3.0",
        "p-timeout": "^7.0.1",
        "radash": "^12.1.1",
        "reflect-metadata": "^0.2.2",
        "simple-git": "^3.33.0",
        "terminal-link": "^5.0.0",
        "ts-morph": "^27.0.2",
        "uuid": "^13.0.0",
        "ws": "^8.19.0",
        "yaml": "2.8.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/chai": "^5",
        "@types/inquirer": "^9.0.9",
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.5.0",
        "@types/uuid": "^11.0.0",
        "@types/ws": "^8.18.1",
        "chai": "^6",
        "eslint": "^9",
        "eslint-config-prettier": "^10",
        "mocha": "^11",
        "shx": "^0.4.0",
        "tslib": "^2.8.1",
        "tsx": "^4.21.0",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.9.3"
    },
    "oclif": {
        "bin": "kinotic",
        "dirname": "kinotic",
        "commands": "./dist/commands",
        "topicSeparator": " ",
        "topics": {
            "create": {
                "description": "Creates Kinotic projects, libraries, and applications"
            }
        }
    },
    "scripts": {
        "build": "shx rm -rf dist && tsc -b && tsc-alias -f && pnpm run copy-files",
        "lint": "eslint . --ext .ts --config .eslintrc",
        "posttest": "pnpm lint",
        "prepack": "pnpm build",
        "test": "mocha --forbid-only \"test/**/*.test.ts\"",
        "version": "git add README.md",
        "copy-files": "cp -r ./src/templates/  ./dist/templates/"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [],
    "types": "dist/index.d.ts"
}
