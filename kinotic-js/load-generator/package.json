    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@kinotic-ai/core": "^1.2.1",
    "@kinotic-ai/idl": "^1.0.9",
