ction",[207,258,259],{},"Production is a full Kubernetes deployment managed through Helm charts:",[211,261,262,265,268,271],{},[214,263,264],{},"High-availability configuration with appropriate replica counts",[214,266,267],{},"Managed data persistence",[214,269,270],{},"TLS termination and ingress configuration",[214,272,273],{},"Monitoring and observability integration",{"title":275,"searchDepth":276,"depth":276,"links":277},"",2,[278,279,280],{"id":204,"depth":276,"text":205},{"id":237,"depth":276,"text":238},{"id":255,"depth":276,"text":256},"Development, staging, and production environment configuration.","md",null,{},{"icon":121},{"title":118,"description":281},"SJGZnRR58gN-s3ICMuJhNCDpDNOuSj7JJiGYvzvGPcQ",[289,291],{"title":113,"path":114,"stem":115,"description":290,"icon":116,"children":-1},"The Kinotic deployment pipeline from development to production.",{"title":123,"path":124,"stem":125,"description":292,"icon":126,"children":-1},"Command reference for the Kinotic CLI.",1776065175411]