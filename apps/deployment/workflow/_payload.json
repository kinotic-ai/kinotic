ce\u002F3.abac-expression-language","i-lucide-file-code",{"title":182,"path":183,"stem":184,"icon":185},"CRI Format","\u002Freference\u002Fcri-format","3.reference\u002F4.cri-format","i-lucide-link",{"title":187,"path":188,"stem":189,"icon":190},"SDK Packages","\u002Freference\u002Fsdk-packages","3.reference\u002F5.sdk-packages","i-lucide-package",{"id":192,"title":113,"body":193,"description":322,"extension":323,"links":324,"meta":325,"navigation":326,"path":114,"seo":327,"stem":115,"__hash__":328},"docs\u002F1.apps\u002F7.deployment\u002F1.workflow.md",{"type":194,"value":195,"toc":310},"minimark",[196,200,204,211,215,218,240,244,247,252,255,269,273,276,290,294,297],[197,198,25],"h2",{"id":199},"overview",[201,202,203],"p",{},"Kinotic provides a built-in deployment pipeline that takes your application from development through staging to production. The pipeline is designed around feature-based development with isolated environments and security-first build processes.",[201,205,206,210],{},[207,208,209],"strong",{},"Pipeline stages:"," Development -> Staging -> Production",[197,212,214],{"id":213},"development","Development",[201,216,217],{},"The development stage is optimized for rapid iteration:",[219,220,221,228,234],"ul",{},[222,223,224,227],"li",{},[207,225,226],{},"Feature isolation"," — Each feature branch gets its own development pod, so developers can test changes without affecting others.",[222,229,230,233],{},[207,231,232],{},"Automatic deployment"," — Changes deploy as code is saved, providing immediate feedback during development.",[222,235,236,239],{},[207,237,238],{},"Firecracker VM isolation"," — Builds execute in isolated Firecracker VMs for both speed and security. Each build runs in its own lightweight VM, preventing untrusted code from affecting the host or other builds.",[197,241,243],{"id":242},"staging","Staging",[201,245,246],{},"The staging environment acts as a gate between development and production. It operates in two phases:",[248,249,251],"h3",{"id":250},"pre-merge-checks","Pre-Merge Checks",[201,253,254],{},"Before a feature branch is merged, the staging environment runs:",[219,256,257,263],{},[222,258,259,262],{},[207,260,261],{},"Vulnerability scanning"," — Automated security checks on dependencies and application code.",[222,264,265,268],{},[207,266,267],{},"Migration execution tests"," — Migration scripts are executed against a staging data store to verify they run correctly before reaching production.",[248,270,272],{"id":271},"post-merge","Post-Merge",[201,274,275],{},"After a feature branch is merged:",[219,277,278,284],{},[222,279,280,283],{},[207,281,282],{},"Full application build"," — The complete application is built and deployed to the staging environment.",[222,285,286,289],{},[207,287,288],{},"Human-in-the-loop approval"," — A team member reviews the staging deployment and explicitly approves promotion to production. No automatic promotion occurs.",[197,291,293],{"id":292},"production","Production",[201,295,296],{},"Production deployment happens only after staging approval:",[219,298,299,304],{},[222,300,301,303],{},[207,302,282],{}," — All projects within the application are built and deployed together.",[222,305,306,309],{},[207,307,308],{},"Deployed after approval"," — The production environment is updated only when a team member has reviewed and approved the staging deployment.",{"title":311,"searchDepth":312,"depth":312,"links":313},"",2,[314,315,316,321],{"id":199,"depth":312,"text":25},{"id":213,"depth":312,"text":214},{"id":242,"depth":312,"text":243,"children":317},[318,320],{"id":250,"depth":319,"text":251},3,{"id":271,"depth":319,"text":272},{"id":292,"depth":312,"text":293},"The Kinotic deployment pipeline from development to production.","md",null,{},{"icon":116},{"title":113,"description":322},"g5MDEflmRXbYi2WnNZsjYvbgX8Lz3yuNFx54M63X4HA",[330,332],{"title":102,"path":103,"stem":104,"description":331,"icon":105,"children":-1},"Authentication methods and identity management in Kinotic.",{"title":118,"path":119,"stem":120,"description":333,"icon":121,"children":-1},"Development, staging, and production environment configuration.",1776066917373]