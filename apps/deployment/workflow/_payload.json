ql-grammar","3.reference\u002F2.migration-sql-grammar",{"title":182,"path":183,"stem":184,"icon":185},"ABAC Expression Language","\u002Freference\u002Fabac-expression-language","3.reference\u002F3.abac-expression-language","i-lucide-file-code",{"title":187,"path":188,"stem":189,"icon":190},"CRI Format","\u002Freference\u002Fcri-format","3.reference\u002F4.cri-format","i-lucide-link",{"title":192,"path":193,"stem":194,"icon":195},"SDK Packages","\u002Freference\u002Fsdk-packages","3.reference\u002F5.sdk-packages","i-lucide-package",{"id":197,"title":113,"body":198,"description":327,"extension":328,"links":329,"meta":330,"navigation":331,"path":114,"seo":332,"stem":115,"__hash__":333},"docs\u002F1.apps\u002F7.deployment\u002F1.workflow.md",{"type":199,"value":200,"toc":315},"minimark",[201,205,209,216,220,223,245,249,252,257,260,274,278,281,295,299,302],[202,203,25],"h2",{"id":204},"overview",[206,207,208],"p",{},"Kinotic provides a built-in deployment pipeline that takes your application from development through staging to production. The pipeline is designed around feature-based development with isolated environments and security-first build processes.",[206,210,211,215],{},[212,213,214],"strong",{},"Pipeline stages:"," Development -> Staging -> Production",[202,217,219],{"id":218},"development","Development",[206,221,222],{},"The development stage is optimized for rapid iteration:",[224,225,226,233,239],"ul",{},[227,228,229,232],"li",{},[212,230,231],{},"Feature isolation"," — Each feature branch gets its own development pod, so developers can test changes without affecting others.",[227,234,235,238],{},[212,236,237],{},"Automatic deployment"," — Changes deploy as code is saved, providing immediate feedback during development.",[227,240,241,244],{},[212,242,243],{},"Firecracker VM isolation"," — Builds execute in isolated Firecracker VMs for both speed and security. Each build runs in its own lightweight VM, preventing untrusted code from affecting the host or other builds.",[202,246,248],{"id":247},"staging","Staging",[206,250,251],{},"The staging environment acts as a gate between development and production. It operates in two phases:",[253,254,256],"h3",{"id":255},"pre-merge-checks","Pre-Merge Checks",[206,258,259],{},"Before a feature branch is merged, the staging environment runs:",[224,261,262,268],{},[227,263,264,267],{},[212,265,266],{},"Vulnerability scanning"," — Automated security checks on dependencies and application code.",[227,269,270,273],{},[212,271,272],{},"Migration execution tests"," — Migration scripts are executed against a staging data store to verify they run correctly before reaching production.",[253,275,277],{"id":276},"post-merge","Post-Merge",[206,279,280],{},"After a feature branch is merged:",[224,282,283,289],{},[227,284,285,288],{},[212,286,287],{},"Full application build"," — The complete application is built and deployed to the staging environment.",[227,290,291,294],{},[212,292,293],{},"Human-in-the-loop approval"," — A team member reviews the staging deployment and explicitly approves promotion to production. No automatic promotion occurs.",[202,296,298],{"id":297},"production","Production",[206,300,301],{},"Production deployment happens only after staging approval:",[224,303,304,309],{},[227,305,306,308],{},[212,307,287],{}," — All projects within the application are built and deployed together.",[227,310,311,314],{},[212,312,313],{},"Deployed after approval"," — The production environment is updated only when a team member has reviewed and approved the staging deployment.",{"title":316,"searchDepth":317,"depth":317,"links":318},"",2,[319,320,321,326],{"id":204,"depth":317,"text":25},{"id":218,"depth":317,"text":219},{"id":247,"depth":317,"text":248,"children":322},[323,325],{"id":255,"depth":324,"text":256},3,{"id":276,"depth":324,"text":277},{"id":297,"depth":317,"text":298},"The Kinotic deployment pipeline from development to production.","md",null,{},{"icon":116},{"title":113,"description":327},"g5MDEflmRXbYi2WnNZsjYvbgX8Lz3yuNFx54M63X4HA",[335,337],{"title":102,"path":103,"stem":104,"description":336,"icon":105,"children":-1},"Authentication methods and identity management in Kinotic.",{"title":118,"path":119,"stem":120,"description":338,"icon":121,"children":-1},"Development, staging, and production environment configuration.",1777527434059]