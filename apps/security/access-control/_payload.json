ant.roles contains 'admin'",[225,422,423,428,431],{},[240,424,425],{},[214,426,427],{},"in",[240,429,430],{},"Value in set",[240,432,433],{},[214,434,435],{},"entity.status in ['active', 'pending']",[225,437,438,443,446],{},[240,439,440],{},[214,441,442],{},"exists",[240,444,445],{},"Field presence",[240,447,448],{},[214,449,450],{},"entity.approvedBy exists",[225,452,453,458,461],{},[240,454,455],{},[214,456,457],{},"like",[240,459,460],{},"Pattern match",[240,462,463],{},[214,464,465],{},"entity.email like '*@kinotic.ai'",[262,467,469],{"id":468},"boolean-logic","Boolean Logic",[201,471,472,473,476,477,480,481,484],{},"Combine conditions with ",[214,474,475],{},"and",", ",[214,478,479],{},"or",", and ",[214,482,483],{},"not",". Parentheses override default precedence. Keywords are case-insensitive.",[201,486,487,490,491,476,493,476,495],{},[205,488,489],{},"Precedence"," (highest to lowest): comparisons, ",[214,492,483],{},[214,494,475],{},[214,496,479],{},[498,499,504],"pre",{"className":500,"code":502,"language":503},[501],"language-text","participant.roles contains 'finance' and order.amount \u003C 50000\n\nentity.status in ['active', 'pending'] or participant.department == entity.department\n\nnot entity.deleted == true\n\n(participant.roles contains 'admin' or participant.roles contains 'manager')\n    and entity.classification != 'top-secret'\n","text",[214,505,502],{"__ignoreMap":506},"",[262,508,510],{"id":509},"literals","Literals",[219,512,513,525],{},[222,514,515],{},[225,516,517,520,523],{},[228,518,519],{},"Type",[228,521,522],{},"Syntax",[228,524,313],{},[235,526,527,540,553,566],{},[225,528,529,532,535],{},[240,530,531],{},"String",[240,533,534],{},"Single quotes",[240,536,537],{},[214,538,539],{},"'finance'",[225,541,542,545,548],{},[240,543,544],{},"Integer",[240,546,547],{},"Digits",[240,549,550],{},[214,551,552],{},"50000",[225,554,555,558,561],{},[240,556,557],{},"Decimal",[240,559,560],{},"Digits with dot",[240,562,563],{},[214,564,565],{},"3.