son File",{"id":438,"depth":328,"text":439},{"id":503,"depth":300,"text":504},"Learn how to configure Kinotic applications and the projects that compose them.","md",null,{},true,{"title":29,"description":578},"1p1lGkSYe8PZdZApV6tSMN6CUqsOuhMOKUg7zN4wZV4",[586,588],{"title":25,"path":26,"stem":27,"description":587,"children":-1},"Understand how Kinotic apps are organized -- from organizations down to individual artifacts.",{"title":33,"path":34,"stem":35,"description":589,"children":-1},"Learn about the different artifact types a Kinotic project can contribute -- from persistence and microservices to frontends.",1775165878484]