u002Freference\u002Fabac-expression-language","3.reference\u002F3.abac-expression-language","i-lucide-file-code",{"title":182,"path":183,"stem":184,"icon":185},"CRI Format","\u002Freference\u002Fcri-format","3.reference\u002F4.cri-format","i-lucide-link",{"title":187,"path":188,"stem":189,"icon":190},"SDK Packages","\u002Freference\u002Fsdk-packages","3.reference\u002F5.sdk-packages","i-lucide-package",{"id":192,"title":29,"body":193,"description":620,"extension":621,"links":622,"meta":623,"navigation":624,"path":30,"seo":625,"stem":31,"__hash__":626},"docs\u002F1.apps\u002F3.application-structure\u002F2.applications-and-projects.md",{"type":194,"value":195,"toc":611},"minimark",[196,200,205,208,236,239,243,257,265,275,419,424,478,482,488,540,543,547,550,601,607],[197,198,199],"p",{},"An application is the deployable unit in Kinotic. Projects are the building blocks that make up an application. This page explains how to configure both.",[201,202,204],"h2",{"id":203},"applications","Applications",[197,206,207],{},"Every application has:",[209,210,211,224,230],"ul",{},[212,213,214,218,219,223],"li",{},[215,216,217],"strong",{},"Name"," -- A unique identifier, typically in reverse-domain style (e.g., ",[220,221,222],"code",{},"com.example.inventory",").",[212,225,226,229],{},[215,227,228],{},"Description"," -- A human-readable summary of what the application does.",[212,231,232,235],{},[215,233,234],{},"Optional API support"," -- Applications can optionally expose a GraphQL and\u002For OpenAPI endpoint that aggregates the services published by their projects.",[197,237,238],{},"Applications are created and managed through the Kinotic CLI and the Kinotic OS dashboard.",[201,240,242],{"id":241},"projects","Projects",[197,244,245,246,249,250,253,254,256],{},"A project is a directory with its own ",[220,247,248],{},"package.json"," and a ",[220,251,252],{},".kinotic.json"," configuration file. The CLI uses ",[220,255,252],{}," to understand how the project fits into the broader application.",[258,259,261,262,264],"h3",{"id":260},"the-kinoticjson-file","The ",[220,263,252],{}," File",[197,266,267,268,271,272,274],{},"When you run ",[220,269,270],{},"kinotic init",", a ",[220,273,252],{}," file is created in your project root:",[276,277,282],"pre",{"className":278,"code":279,"language":280,"meta":281,"style":281},"language-json shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","{\n    \"application\": \"my.app\",\n    \"entitiesPaths\": [\n        {\n            \"path\": \"src\u002Fentities\",\n            \"repositoryPath\": \"src\u002Fgenerated\",\n            \"mirrorFolderStructure\": true\n        }\n    ]\n}\n","json","",[220,283,284,293,321,336,342,365,386,401,407,413],{"__ignoreMap":281},[285,286,289],"span",{"class":287,"line":288},"line",1,[285,290,292],{"class":291},"sMK4o","{\n",[285,294,296,299,303,306,309,312,316,318],{"class":287,"line":295},2,[285,297,298],{"class":291},"    \"",[285,300,302],{"class":301},"spNyl","application",[285,304,305],{"class":291},"\"",[285,307,308],{"class":291},":",[285,310,311],{"class":291}," \"",[285,313,315],{"class":314},"sfazB","my.app",[285,317,305],{"class":291},[285,319,320],{"class":291},",\n",[285,322,324,326,329,331,333],{"class":287,"line":323},3,[285,325,298],{"class":291},[285,327,328],{"class":301},"entitiesPaths",[285,330,305],{"class":291},[285,332,308],{"class":291},[285,334,335],{"class":291}," [\n",[285,337,339],{"class":287,"line":338},4,[285,340,341],{"class":291},"        {\n",[285,343,345,348,352,354,356,358,361,363],{"class":287,"line":344},5,[285,346,347],{"class":291},"            \"",[285,349,351],{"class":350},"sBMFI","path",[285,353,305],{"class":291},[285,355,308],{"class":291},[285,357,311],{"class":291},[285,359,360],{"class":314},"src\u002Fentities",[285,362,305],{"class":291},[285,364,320],{"class":291},[285,366,368,370,373,375,377,379,382,384],{"class":287,"line":367},6,[285,369,347],{"class":291},[285,371,372],{"class":350},"repositoryPath",[285,374,305],{"class":291},[285,376,308],{"class":291},[285,378,311],{"class":291},[285,380,381],{"class":314},"src\u002Fgenerated",[285,383,305],{"class":291},[285,385,320],{"class":291},[285,387,389,391,394,396,398],{"class":287,"line":388},7,[285,390,347],{"class":291},[285,392,393],{"class":350},"mirrorFolderStructure",[285,395,305],{"class":291},[285,397,308],{"class":291},[285,399,400],{"class":291}," true\n",[285,402,404],{"class":287,"line":403},8,[285,405,406],{"class":291},"        }\n",[285,408,410],{"class":287,"line":409},9,[285,411,412],{"class":291},"    ]\n",[285,414,416],{"class":287,"line":415},10,[285,417,418],{"class":291},"}\n",[420,421,423],"h4",{"id":422},"fields","Fields",[425,426,427,439],"table",{},[428,429,430],"thead",{},[431,432,433,437],"tr",{},[434,435,436],"th",{},"Field",[434,438,228],{},[440,441,442,452],"tbody",{},[431,443,444,449],{},[445,446,447],"td",{},[220,448,302],{},[445,450,451],{},"The application identifier this project belongs to. Must match the application name registered with Kinotic OS.",[431,453,454,458],{},[445,455,456],{},[220,457,328],{},[445,459,460,461,464,465,467,468,470,471,473,474,477],{},"An array of ",[220,462,463],{},"EntitiesPathConfig"," objects. Each object specifies ",[220,466,351],{}," (the directory containing entity definitions), ",[220,469,372],{}," (where the CLI writes auto-generated repository classes), and ",[220,472,393],{}," (whether to replicate the entity directory structure in the output). The CLI scans these paths when you run ",[220,475,476],{},"kinotic sync",".",[258,479,481],{"id":480},"project-dependencies","Project Dependencies",[197,483,484,485,487],{},"Projects within the same application can depend on each other. For example, a microservice project might import entity types defined in a persistence project. These dependencies are managed through standard ",[220,486,248],{}," -- you add the dependency just like any other Bun package.",[276,489,491],{"className":278,"code":490,"language":280,"meta":281,"style":281},"{\n    \"dependencies\": {\n        \"@my-org\u002Fdata\": \"workspace:*\"\n    }\n}\n",[220,492,493,497,511,531,536],{"__ignoreMap":281},[285,494,495],{"class":287,"line":288},[285,496,292],{"class":291},[285,498,499,501,504,506,508],{"class":287,"line":295},[285,500,298],{"class":291},[285,502,503],{"class":301},"dependencies",[285,505,305],{"class":291},[285,507,308],{"class":291},[285,509,510],{"class":291}," {\n",[285,512,513,516,519,521,523,525,528],{"class":287,"line":323},[285,514,515],{"class":291},"        \"",[285,517,518],{"class":350},"@my-org\u002Fdata",[285,520,305],{"class":291},[285,522,308],{"class":291},[285,524,311],{"class":291},[285,526,527],{"class":314},"workspace:*",[285,529,530],{"class":291},"\"\n",[285,532,533],{"class":287,"line":338},[285,534,535],{"class":291},"    }\n",[285,537,538],{"class":287,"line":344},[285,539,418],{"class":291},[197,541,542],{},"When the application is deployed, the platform resolves these internal dependencies and ensures all projects are available to each other through the Service Directory.",[201,544,546],{"id":545},"typical-setup","Typical Setup",[197,548,549],{},"Most applications start with a single project that handles persistence:",[276,551,555],{"className":552,"code":553,"language":554,"meta":281,"style":281},"language-bash shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","mkdir my-app && cd my-app\nkinotic init --application my.app --entities src\u002Fentities --repository src\u002Fgenerated\n","bash",[220,556,557,575],{"__ignoreMap":281},[285,558,559,562,565,568,572],{"class":287,"line":288},[285,560,561],{"class":350},"mkdir",[285,563,564],{"class":314}," my-app",[285,566,567],{"class":291}," &&",[285,569,571],{"class":570},"s2Zo4"," cd",[285,573,574],{"class":314}," my-app\n",[285,576,577,580,583,586,589,592,595,598],{"class":287,"line":295},[285,578,579],{"class":350},"kinotic",[285,581,582],{"class":314}," init",[285,584,585],{"class":314}," --application",[285,587,588],{"class":314}," my.app",[285,590,591],{"class":314}," --entities",[285,593,594],{"class":314}," src\u002Fentities",[285,596,597],{"class":314}," --repository",[285,599,600],{"class":314}," src\u002Fgenerated\n",[197,602,603,604,606],{},"As the application grows, you can add additional projects for microservices, batch jobs, or frontends -- each with its own ",[220,605,252],{}," pointing to the same application identifier.",[608,609,610],"style",{},"html pre.shiki code .sMK4o, html code.shiki .sMK4o{--shiki-light:#39ADB5;--shiki-default:#89DDFF;--shiki-dark:#89DDFF}html pre.shiki code .spNyl, html code.shiki .spNyl{--shiki-light:#9C3EDA;--shiki-default:#C792EA;--shiki-dark:#C792EA}html pre.shiki code .sfazB, html code.shiki .sfazB{--shiki-light:#91B859;--shiki-default:#C3E88D;--shiki-dark:#C3E88D}html pre.shiki code .sBMFI, html code.shiki .sBMFI{--shiki-light:#E2931D;--shiki-default:#FFCB6B;--shiki-dark:#FFCB6B}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--s