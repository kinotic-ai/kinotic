02F7.deployment\u002F1.workflow","i-lucide-git-branch",{"title":118,"path":119,"stem":120,"icon":121},"Environments","\u002Fapps\u002Fdeployment\u002Fenvironments","1.apps\u002F7.deployment\u002F2.environments","i-lucide-server",{"title":123,"path":124,"stem":125,"icon":126},"CLI Reference","\u002Fapps\u002Fcli-reference","1.apps\u002F8.cli-reference","i-lucide-terminal",{"title":128,"icon":121,"path":129,"stem":130,"children":131,"page":36},"Kinotic OS","\u002Fplatform","2.platform",[132,137,141,146,151,156],{"title":133,"path":134,"stem":135,"icon":136},"System Architecture","\u002Fplatform\u002Farchitecture","2.platform\u002F1.architecture","i-lucide-boxes",{"title":138,"path":139,"stem":140,"icon":6},"Deployment Guide","\u002Fplatform\u002Fdeployment-guide","2.platform\u002F2.deployment-guide",{"title":142,"path":143,"stem":144,"icon":145},"Configuration","\u002Fplatform\u002Fconfiguration","2.platform\u002F3.configuration","i-lucide-settings",{"title":147,"path":148,"stem":149,"icon":150},"System Security","\u002Fplatform\u002Fsystem-security","2.platform\u002F5.system-security","i-lucide-shield",{"title":152,"path":153,"stem":154,"icon":155},"Observability","\u002Fplatform\u002Fobservability","2.platform\u002F6.observability","i-lucide-activity",{"title":157,"path":158,"stem":159,"icon":160},"Contributing","\u002Fplatform\u002Fcontributing","2.platform\u002F7.contributing","i-lucide-git-pull-request",{"title":162,"icon":163,"path":164,"stem":165,"children":166,"page":36},"Reference","i-lucide-book-open","\u002Freference","3.reference",[167,172,176,181,186],{"title":168,"path":169,"stem":170,"icon":171},"Decorators Reference","\u002Freference\u002Fdecorators","3.reference\u002F1.decorators","i-lucide-at-sign",{"title":173,"path":174,"stem":175,"icon":60},"Migration SQL Grammar","\u002Freference\u002Fmigration-sql-grammar","3.reference\u002F2.migration-sql-grammar",{"title":177,"path":178,"stem":179,"icon":180},"ABAC Expression Language","\u002Freference\u002Fabac-expression-language","3.reference\u002F3.abac-expression-language","i-lucide-file-code",{"title":182,"path":183,"stem":184,"icon":185},"CRI Format","\u002Freference\u002Fcri-format","3.reference\u002F4.cri-format","i-lucide-link",{"title":187,"path":188,"stem":189,"icon":190},"SDK Packages","\u002Freference\u002Fsdk-packages","3.reference\u002F5.sdk-packages","i-lucide-package",{"id":192,"title":33,"body":193,"description":472,"extension":473,"links":474,"meta":475,"navigation":476,"path":34,"seo":477,"stem":35,"__hash__":478},"docs\u002F1.apps\u002F3.application-structure\u002F3.artifact-types.md",{"type":194,"value":195,"toc":462},"minimark",[196,205,209,212,217,241,246,257,260,264,267,271,279,283,294,297,301,304,308,316,320,328,332,335,339,344,348,353,357,360,364,369,373,381,385,388,459],[197,198,199,200,204],"p",{},"Every project in a Kinotic application contributes one or more ",[201,202,203],"strong",{},"artifacts",". An artifact is a typed output that the platform knows how to build, deploy, and manage. This page describes each artifact type and when to use it.",[206,207,59],"h2",{"id":208},"persistence",[197,210,211],{},"The most common starting point. A persistence artifact defines your domain models (entities) and gets auto-generated CRUD services in return.",[197,213,214],{},[201,215,216],{},"What you provide:",[218,219,220],"ul",{},[221,222,223,224,228,229,232,233,236,237,240],"li",{},"Entity classes decorated with ",[225,226,227],"code",{},"@Entity"," and field-level annotations like ",[225,230,231],{},"@NotNull",", ",[225,234,235],{},"@Precision",", and ",[225,238,239],{},"@AutoGeneratedId",".",[197,242,243],{},[201,244,245],{},"What the platform provides:",[218,247,248,251,254],{},[221,249,250],{},"Full CRUD operations (save, find, delete) with pagination and sorting.",[221,252,253],{},"Named queries derived from method naming conventions.",[221,255,256],{},"Automatic storage provisioning and indexing.",[197,258,259],{},"Persistence is typically the first artifact you create because it establishes the data model that the rest of the application builds on.",[206,261,263],{"id":262},"microservice","Microservice",[197,265,266],{},"A microservice artifact is long-running code that executes in a pod or VM. It publishes services that other parts of the application can discover and call through auto-generated proxies.",[197,268,269],{},[201,270,216],{},[218,272,273,276],{},[221,274,275],{},"TypeScript classes that implement your business logic.",[221,277,278],{},"Service interfaces that you want to expose to the rest of the application.",[197,280,281],{},[201,282,245],{},[218,284,285,288,291],{},[221,286,287],{},"Automatic service registration in the Service Directory.",[221,289,290],{},"Auto-generated proxy classes so other projects can call your service with a simple function call.",[221,292,293],{},"Lifecycle management, scaling, and health monitoring.",[197,295,296],{},"Use a microservice when your logic goes beyond simple CRUD -- orchestrating across multiple entities, calling external APIs, or running long-lived workflows.",[206,298,300],{"id":299},"batch-job","Batch Job",[197,302,303],{},"A batch job artifact is code that runs on a schedule. It is ideal for periodic tasks like data aggregation, report generation, cleanup routines, or syncing with external systems.",[197,305,306],{},[201,307,216],{},[218,309,310,313],{},[221,311,312],{},"TypeScript code that performs the job.",[221,314,315],{},"A schedule definition (cron expression or interval).",[197,317,318],{},[201,319,245],{},[218,321,322,325],{},[221,323,324],{},"Scheduled execution with retry and failure handling.",[221,326,327],{},"Logging and observability for each run.",[206,329,331],{"id":330},"ui-component","UI Component",[197,333,334],{},"A UI component artifact produces reusable building blocks that can be shared across multiple frontends within the application. Think of it as an internal component library.",[197,336,337],{},[201,338,216],{},[218,340,341],{},[221,342,343],{},"Reusable UI components packaged for consumption by frontend projects.",[197,345,346],{},[201,347,245],{},[218,349,350],{},[221,351,352],{},"Versioning and distribution within the application.",[206,354,356],{"id":355},"frontend","Frontend",[197,358,359],{},"A frontend artifact is a complete user interface that gets deployed as a static site. It consumes services published by other projects in the application.",[197,361,362],{},[201,363,216],{},[218,365,366],{},[221,367,368],{},"A web application (built with any framework) that compiles to static assets.",[197,370,371],{},[201,372,245],{},[218,374,375,378],{},[221,376,377],{},"Static hosting with CDN distribution.",[221,379,380],{},"Automatic connection to the application's services through the Kinotic client libraries.",[206,382,384],{"id":383},"combining-artifact-types","Combining Artifact Types",[197,386,387],{},"Most real-world applications combine several artifact types. A typical setup might look like this:",[389,390,391,407],"table",{},[392,393,394],"thead",{},[395,396,397,401,404],"tr",{},[398,399,400],"th",{},"Project",[398,402,403],{},"Artifact Type",[398,405,406],{},"Role",[408,409,410,423,435,447],"tbody",{},[395,411,412,418,420],{},[413,414,415],"td",{},[225,416,417],{},"data",[413,419,59],{},[413,421,422],{},"Defines entities and provides auto-generated CRUD services",[395,424,425,430,432],{},[413,426,427],{},[225,428,429],{},"services",[413,431,263],{},[413,433,434],{},"Implements business rules that orchestrate across entities",[395,436,437,442,444],{},[413,438,439],{},[225,440,441],{},"jobs",[413,443,300],{},[413,445,446],{},"Runs nightly data aggregation",[395,448,449,454,456],{},[413,450,451],{},[225,452,453],{},"web",[413,455,356],{},[413,457,458],{},"The main user interface",[197,460,461],{},"Each project is independently developed and versioned, but they all deploy as part of the same application and communicate through the Service Directory.",{"title":463,"searchDepth":464,"depth":464,"links":465},"",2,[466,467,468,469,470,471],{"id":208,"depth":464,"text":59},{"id":262,"depth":464,"text":263},{"id":299,"depth":464,"text":300},{"id":330,"depth":464,"text":331},{"id":355,"depth":464,"text":356},{"id":383,"depth":464,"text":384},"Learn about the different artifact types a Kinotic project can contribute -- from persistence and microservices to frontends.","md",null,{},true,{"title":33,"description":472},"dDAlaopYkhCbmvVm9Gwq3HGiUp4fe4-9-fb1rRp24v8",[480,482],{"title":29,"path":30,"stem":31,"description":481,"children":-1},"Learn how to configure Kinotic applications and the projects that compose them.",{"title":25,"path":44,"stem":45,"description":483,"children":-1},"How services work in Kinotic and the communication patterns they support.",1776745208168]