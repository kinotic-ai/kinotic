eference\u002F3.abac-expression-language","i-lucide-file-code",{"title":182,"path":183,"stem":184,"icon":185},"CRI Format","\u002Freference\u002Fcri-format","3.reference\u002F4.cri-format","i-lucide-link",{"title":187,"path":188,"stem":189,"icon":190},"SDK Packages","\u002Freference\u002Fsdk-packages","3.reference\u002F5.sdk-packages","i-lucide-package",{"id":192,"title":88,"body":193,"description":509,"extension":510,"links":511,"meta":512,"navigation":513,"path":89,"seo":514,"stem":90,"__hash__":515},"docs\u002F1.apps\u002F5.persistence\u002F7.migrations.md",{"type":194,"value":195,"toc":492},"minimark",[196,205,210,213,223,226,245,252,256,273,277,298,302,307,310,318,322,325,334,338,341,350,354,357,366,370,373,382,386,389,398,402,405,414,418,421,430,434,481,488],[197,198,199,200,204],"p",{},"Migrations let you evolve your data schema in a controlled, versioned way. They are written in a SQL-like syntax and executed automatically during ",[201,202,203],"code",{},"kinotic sync",".",[206,207,209],"h2",{"id":208},"file-naming","File Naming",[197,211,212],{},"Migration files follow a strict naming convention:",[214,215,220],"pre",{"className":216,"code":218,"language":219},[217],"language-text","V\u003Cnumber>__\u003Cdescription>.sql\n","text",[201,221,218],{"__ignoreMap":222},"",[197,224,225],{},"Examples:",[227,228,229,235,240],"ul",{},[230,231,232],"li",{},[201,233,234],{},"V1__initial_schema.sql",[230,236,237],{},[201,238,239],{},"V2__add_email_field.sql",[230,241,242],{},[201,243,244],{},"V3__create_sensor_readings.sql",[197,246,247,248,251],{},"The version number determines execution order. The double underscore (",[201,249,250],{},"__",") separates the version from the description.",[206,253,255],{"id":254},"how-it-works","How It Works",[257,258,259,262,265,268],"ol",{},[230,260,261],{},"Migration files are discovered and sorted by version number",[230,263,264],{},"Only unapplied migrations are parsed and executed",[230,266,267],{},"Each migration is recorded after successful execution to prevent re-runs",[230,269,270,271],{},"Migrations run during ",[201,272,203],{},[206,274,276],{"id":275},"example-migration","Example Migration",[214,278,282],{"className":279,"code":280,"language":281,"meta":222,"style":222},"language-sql shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","-- V1__initial_schema.sql\nCREATE TABLE users (name TEXT, age INTEGER, active BOOLEAN);\n","sql",[201,283,284,292],{"__ignoreMap":222},[285,286,289],"span",{"class":287,"line":288},"line",1,[285,290,291],{},"-- V1__initial_schema.sql\n",[285,293,295],{"class":287,"line":294},2,[285,296,297],{},"CREATE TABLE users (name TEXT, age INTEGER, active BOOLEAN);\n",[206,299,301],{"id":300},"supported-statements","Supported Statements",[303,304,306],"h3",{"id":305},"create-table","CREATE TABLE",[197,308,309],{},"Create a new table with field mappings.",[214,311,312],{"className":279,"code":297,"language":281,"meta":222,"style":222},[201,313,314],{"__ignoreMap":222},[285,315,316],{"class":287,"line":288},[285,317,297],{},[303,319,321],{"id":320},"create-component-template","CREATE COMPONENT TEMPLATE",[197,323,324],{},"Define reusable templates with settings that can be applied to multiple tables.",[214,326,328],{"className":279,"code":327,"language":281,"meta":222,"style":222},"CREATE COMPONENT TEMPLATE my_settings WITH (number_of_shards = 1, number_of_replicas = 0);\n",[201,329,330],{"__ignoreMap":222},[285,331,332],{"class":287,"line":288},[285,333,327],{},[303,335,337],{"id":336},"create-index-template","CREATE INDEX TEMPLATE",[197,339,340],{},"Create templates that automatically apply to tables matching a name pattern.",[214,342,344],{"className":279,"code":343,"language":281,"meta":222,"style":222},"CREATE INDEX TEMPLATE my_template MATCHING (logs-*) COMPOSED OF (my_settings);\n",[201,345,346],{"__ignoreMap":222},[285,347,348],{"class":287,"line":288},[285,349,343],{},[303,351,353],{"id":352},"alter-table-add-column","ALTER TABLE ADD COLUMN",[197,355,356],{},"Add new fields to an existing table.",[214,358,360],{"className":279,"code":359,"language":281,"meta":222,"style":222},"ALTER TABLE users ADD COLUMN email TEXT;\n",[201,361,362],{"__ignoreMap":222},[285,363,364],{"class":287,"line":288},[285,365,359],{},[303,367,369],{"id":368},"reindex","REINDEX",[197,371,372],{},"Migrate data between tables with advanced options.",[214,374,376],{"className":279,"code":375,"language":281,"meta":222,"style":222},"REINDEX FROM old_index INTO new_index WITH (SKIP_IF_NO_SOURCE = TRUE);\n",[201,377,378],{"__ignoreMap":222},[285,379,380],{"class":287,"line":288},[285,381,375],{},[303,383,385],{"id":384},"insert-into","INSERT INTO",[197,387,388],{},"Add records to a table.",[214,390,392],{"className":279,"code":391,"language":281,"meta":222,"style":222},"INSERT INTO users (name, age, active) VALUES ('Jane', 28, TRUE) WITH REFRESH;\n",[201,393,394],{"__ignoreMap":222},[285,395,396],{"class":287,"line":288},[285,397,391],{},[303,399,401],{"id":400},"update-set-where","UPDATE ... SET ... WHERE",[197,403,404],{},"Modify existing records.",[214,406,408],{"className":279,"code":407,"language":281,"meta":222,"style":222},"UPDATE users SET active = FALSE WHERE age \u003C 18 WITH REFRESH;\n",[201,409,410],{"__ignoreMap":222},[285,411,412],{"class":287,"line":288},[285,413,407],{},[303,415,417],{"id":416},"delete-from-where","DELETE FROM ... WHERE",[197,419,420],{},"Remove records matching a condition.",[214,422,424],{"className":279,"code":423,"language":281,"meta":222,"style":222},"DELETE FROM users WHERE active = FALSE WITH REFRESH;\n",[201,425,426],{"__ignoreMap":222},[285,427,428],{"class":287,"line":288},[285,429,423],{},[206,431,433],{"id":432},"best-practices","Best Practices",[227,435,436,443,453,461,469,475],{},[230,437,438,442],{},[439,440,441],"strong",{},"Increment version numbers sequentially"," - Gaps are allowed but order must be maintained",[230,444,445,452],{},[439,446,447,448,451],{},"Use ",[201,449,450],{},"IF NOT EXISTS"," where available"," - Makes migrations safe to re-run if the tracking state is reset",[230,454,455,460],{},[439,456,447,457],{},[201,458,459],{},"WITH REFRESH"," on INSERT, UPDATE, and DELETE when subsequent migrations depend on the changed data being immediately visible",[230,462,463,468],{},[439,464,447,465],{},[201,466,467],{},"SKIP_IF_NO_SOURCE = TRUE"," on REINDEX operations for idempotent data migrations",[230,470,471,474],{},[439,472,473],{},"Keep migrations small and focused"," - One logical change per migration file",[230,476,477,480],{},[439,478,479],{},"Never modify a migration after it has been applied"," - Create a new migration instead",[197,482,483,484,204],{},"For the complete SQL grammar reference, see the ",[485,486,487],"a",{"href":174},"Migration SQL Grammar Reference",[489,490,491],"style",{},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki