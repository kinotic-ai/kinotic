e implements INotificationService {\n\n    private readonly serviceProxy: IServiceProxy\n\n    constructor(kinotic: IKinotic) {\n        this.serviceProxy = kinotic.serviceProxy('com.example.NotificationService')\n    }\n\n    sendAlert(message: string): Promise\u003Cvoid> {\n        return this.serviceProxy.invoke('sendAlert', [message])\n    }\n\n    watchAlerts(severity: string): Observable\u003CAlert> {\n        return this.serviceProxy.invokeStream('watchAlerts', [severity])\n    }\n}\n","typescript","",[222,249,250,292,315,322,339,374,400,406,411,429,434,451,456,476,510,516,521,547,582,587,592,617,648,653],{"__ignoreMap":247},[251,252,255,259,262,266,270,273,276,279,282,285,289],"span",{"class":253,"line":254},"line",1,[251,256,258],{"class":257},"s7zQu","import",[251,260,261],{"class":257}," type",[251,263,265],{"class":264},"sMK4o"," {",[251,267,269],{"class":268},"sTEyZ"," IKinotic",[251,271,272],{"class":264},",",[251,274,275],{"class":268}," IServiceProxy",[251,277,278],{"class":264}," }",[251,280,281],{"class":257}," from",[251,283,284],{"class":264}," '",[251,286,288],{"class":287},"sfazB","@kinotic-ai\u002Fcore",[251,290,291],{"class":264},"'\n",[251,293,295,297,299,301,304,306,308,310,313],{"class":253,"line":294},2,[251,296,258],{"class":257},[251,298,261],{"class":257},[251,300,265],{"class":264},[251,302,303],{"class":268}," Observable",[251,305,278],{"class":264},[251,307,281],{"class":257},[251,309,284],{"class":264},[251,311,312],{"class":287},"rxjs",[251,314,291],{"class":264},[251,316,318],{"class":253,"line":317},3,[251,319,321],{"emptyLinePlaceholder":320},true,"\n",[251,323,325,328,332,336],{"class":253,"line":324},4,[251,326,327],{"class":257},"export",[251,329,331],{"class":330},"spNyl"," interface",[251,333,335],{"class":334},"sBMFI"," INotificationService",[251,337,338],{"class":264}," {\n",[251,340,342,346,349,353,356,359,362,365,368,371],{"class":253,"line":341},5,[251,343,345],{"class":344},"swJcz","    sendAlert",[251,347,348],{"cla