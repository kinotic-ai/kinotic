# Default environment variables for production/deployed builds
# These values are used when the app is served from the structures-server

# Continuum WebSocket connection settings
# Empty values will fall back to code defaults
VITE_CONTINUUM_PORT=443
VITE_CONTINUUM_HOST=kinotic.local
VITE_CONTINUUM_USE_SSL=true
; VITE_STATIC_SITE_PORT=9090 ## used during local testing cli
