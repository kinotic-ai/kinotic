language","3.reference\u002F3.abac-expression-language","i-lucide-file-code",{"title":182,"path":183,"stem":184,"icon":185},"CRI Format","\u002Freference\u002Fcri-format","3.reference\u002F4.cri-format","i-lucide-link",{"title":187,"path":188,"stem":189,"icon":190},"SDK Packages","\u002Freference\u002Fsdk-packages","3.reference\u002F5.sdk-packages","i-lucide-package",{"id":192,"title":177,"body":193,"description":789,"extension":790,"links":791,"meta":792,"navigation":793,"path":178,"seo":794,"stem":179,"__hash__":795},"docs\u002F3.reference\u002F3.abac-expression-language.md",{"type":194,"value":195,"toc":763},"minimark",[196,200,213,217,220,225,265,269,278,307,311,321,325,491,495,502,509,516,535,539,554,558,561,600,603,609,613,699,703,707,713,717,723,727,733,737,743,747,753,757],[197,198,25],"h2",{"id":199},"overview",[201,202,203,204,208,209,212],"p",{},"The ABAC (Attribute-Based Access Control) expression language is used to write policy expressions for both service method authorization and entity data filtering. The same syntax works in both ",[205,206,207],"code",{},"@AbacPolicy"," (service methods) and ",[205,210,211],{},"$AbacPolicy"," (entity decorators).",[197,214,216],{"id":215},"attribute-paths","Attribute Paths",[201,218,219],{},"Expressions reference attributes using dotted notation. The root identifier determines what the path resolves against.",[221,222,224],"h3",{"id":223},"reserved-roots","Reserved Roots",[226,227,228,241],"table",{},[229,230,231],"thead",{},[232,233,234,238],"tr",{},[235,236,237],"th",{},"Root",[235,239,240],{},"Description",[242,243,244,255],"tbody",{},[232,245,246,252],{},[247,248,249],"td",{},[205,250,251],{},"participant",[247,253,254],{},"The authenticated caller. Access roles, department, limits, and other identity attributes.",[232,256,257,262],{},[247,258,259],{},[205,260,261],{},"context",[247,263,264],{},"The request environment. Access time, IP address, and other contextual data.",[221,266,268],{"id":267},"dynamic-roots","Dynamic Roots",[201,270,271,272,274,275,277],{},"Any root identifier that is not ",[205,273,251],{}," or ",[205,276,261],{}," is resolved based on the policy context:",[279,280,281,297],"ul",{},[282,283,284,288,289,292,293,296],"li",{},[285,286,287],"strong",{},"Service method policies"," — Resolved against method parameter names. For ",[205,290,291],{},"placeOrder(order: Order)",", the root ",[205,294,295],{},"order"," refers to the first argument.",[282,298,299,302,303,306],{},[285,300,301],{},"Entity policies"," — The root ",[205,304,305],{},"entity"," refers to the entity being accessed.",[221,308,310],{"id":309},"examples","Examples",[312,313,318],"pre",{"className":314,"code":316,"language":317},[315],"language-text","participant.roles                  -- caller's roles array\nparticipant.department             -- caller's department\nparticipant.transferLimit          -- caller's transfer limit\ncontext.time                       -- request timestamp\nentity.ownerId                     -- entity's ownerId field\nentity.sharedWith                  -- entity's sharedWith array\norder.amount                       -- method parameter's amount field\ntransfer.fromAccount               -- method parameter's fromAccount field\n","text",[205,319,316],{"__ignoreMap":320},"",[197,322,324],{"id":323},"operators","Operators",[226,326,327,339],{},[229,328,329],{},[232,330,331,334,336],{},[235,332,333],{},"Operator",[235,335,240],{},[235,337,338],{},"Example",[242,340,341,356,371,386,401,416,431,446,461,476],{},[232,342,343,348,351],{},[247,344,345],{},[205,346,347],{},"==",[247,349,350],{},"Equals",[247,352,353],{},[205,354,355],{},"participant.department == 'engineering'",[232,357,358,363,366],{},[247,359,360],{},[205,361,362],{},"!=",[247,364,365],{},"Not equals",[247,367,368],{},[205,369,370],{},"entity.status != 'archived'",[232,372,373,378,381],{},[247,374,375],{},[205,376,377],{},"\u003C",[247,379,380],{},"Less than",[247,382,383],{},[205,384,385],{},"order.amount \u003C 50000",[232,387,388,393,396],{},[247,389,390],{},[205,391,392],{},">",[247,394,395],{},"Greater than",[247,397,398],{},[205,399,400],{},"entity.priority > 3",[232,402,403,408,411],{},[247,404,405],{},[205,406,407],{},"\u003C=",[247,409,410],{},"Less than or equal",[247,412,413],{},[205,414,415],{},"transfer.amount \u003C= participant.transferLimit",[232,417,418,423,426],{},[247,419,420],{},[205,421,422],{},">=",[247,424,425],{},"Greater than or equal",[247,427,428],{},[205,429,430],{},"entity.score >= 80",[232,432,433,438,441],{},[247,434,435],{},[205,436,437],{},"contains",[247,439,440],{},"Collection membership",[247,442,443],{},[205,444,445],{},"participant.roles contains 'admin'",[232,447,448,453,456],{},[247,449,450],{},[205,451,452],{},"in",[247,454,455],{},"Value in set",[247,457,458],{},[205,459,460],{},"entity.status in ['active', 'pending']",[232,462,463,468,471],{},[247,464,465],{},[205,466,467],{},"exists",[247,469,470],{},"Field presence",[247,472,473],{},[205,474,475],{},"entity.approvedBy exists",[232,477,478,483,486],{},[247,479,480],{},[205,481,482],{},"like",[247,484,485],{},"Pattern match (wildcards)",[247,487,488],{},[205,489,490],{},"entity.email like '*@kinotic.ai'",[221,492,494],{"id":493},"operator-details","Operator Details",[201,496,497,501],{},[285,498,499],{},[205,500,437],{}," — Tests whether a collection (array) includes a value. The left side must be a collection attribute.",[201,503,504,508],{},[285,505,506],{},[205,507,452],{}," — Tests whether a value is present in a literal set. The right side must be a bracketed list of literals.",[201,510,511,515],{},[285,512,513],{},[205,514,467],{}," — Tests whether a field is present and non-null. No right-hand value is needed.",[201,517,518,522,523,526,527,530,531,534],{},[285,519,520],{},[205,521,482],{}," — Pattern matching with ",[205,524,525],{},"*"," as a wildcard. ",[205,528,529],{},"*@kinotic.ai"," matches any string ending with ",[205,532,533],{},"@kinotic.ai",".",[197,536,538],{"id":537},"boolean-logic","Boolean Logic",[201,540,541,542,545,546,549,550,553],{},"Combine conditions with ",[205,543,544],{},"and",", ",[205,547,548],{},"or",", and ",[205,551,552],{},"not",". Parentheses override default precedence. All keywords are case-insensitive.",[221,555,557],{"id":556},"precedence","Precedence",[201,559,560],{},"From highest to lowest:",[562,563,564,588,592,596],"ol",{},[282,565,566,567,545,569,545,571,545,573,545,575,545,577,545,579,545,581,545,583,545,585,587],{},"Comparisons (",[205,568,347],{},[205,570,362],{},[205,572,377],{},[205,574,392],{},[205,576,407],{},[205,578,422],{},[205,580,437],{},[205,582,452],{},[205,584,467],{},[205,586,482],{},")",[282,589,590],{},[205,591,552],{},[282,593,594],{},[205,595,544],{},[282,597,598],{},[205,599,548],{},[221,601,310],{"id":602},"examples-1",[312,604,607],{"className":605,"code":606,"language":317},[315],"-- AND: both conditions must be true\nparticipant.roles contains 'finance' and order.amount \u003C 50000\n\n-- OR: either condition must be true\nentity.status in ['active', 'pending'] or participant.department == entity.department\n\n-- NOT: negates the condition\nnot entity.deleted == true\n\n-- Parentheses: override precedence\n(participant.roles contains 'admin' or participant.roles contains 'manager')\n    and entity.classification != 'top-secret'\n",[205,608,606],{"__ignoreMap":320},[197,610,612],{"id":611},"literals","Literals",[226,614,615,627],{},[229,616,617],{},[232,618,619,622,625],{},[235,620,621],{},"Type",[235,623,624],{},"Syntax",[235,626,338],{},[242,628,629,642,655,668,686],{},[232,630,631,634,637],{},[247,632,633],{},"String",[247,635,636],{},"Single quotes",[247,638,639],{},[205,640,641],{},"'finance'",[232,643,644,647,650],{},[247,645,646],{},"Integer",[247,648,649],{},"Digits",[247,651,652],{},[205,653,654],{},"50000",[232,656,657,660,663],{},[247,658,659],{},"Decimal",[247,661,662],{},"Digits with dot",[247,664,665],{},[205,666,667],{},"3.14",[232,669,670,673,682],{},[247,671,672],{},"Boolean",[247,674,675,678,679],{},[205,676,677],{},"true"," \u002F ",[205,680,681],{},"false",[247,683,684],{},[205,685,677],{},[232,687,688,691,694],{},[247,689,690],{},"Set",[247,692,693],{},"Brackets with literals",[247,695,696],{},[205,697,698],{},"['active', 'pending']",[197,700,702],{"id":701},"common-patterns","Common Patterns",[221,704,706],{"id":705},"role-checks","Role Checks",[312,708,711],{"className":709,"code":710,"language":317},[315],"-- Single role\nparticipant.roles contains 'admin'\n\n-- Any of multiple roles (OR)\nparticipant.roles contains 'admin' or participant.roles contains 'manager'\n\n-- All of multiple roles (AND)\nparticipant.roles contains 'finance' and participant.roles contains 'approver'\n",[205,712,710],{"__ignoreMap":320},[221,714,716],{"id":715},"ownership","Ownership",[312,718,721],{"className":719,"code":720,"language":317},[315],"-- Entity owner\nentity.ownerId == participant.id\n\n-- Owner or shared\nentity.ownerId == participant.id or entity.sharedWith contains participant.id\n",[205,722,720],{"__ignoreMap":320},[221,724,726],{"id":725},"department-based","Department-Based",[312,728,731],{"className":729,"code":730,"language":317},[315],"-- Same department\nentity.department == participant.department\n\n-- Specific department\nparticipant.department == 'engineering'\n",[205,732,730],{"__ignoreMap":320},[221,734,736],{"id":735},"amount-limits","Amount Limits",[312,738,741],{"className":739,"code":740,"language":317},[315],"-- Under a fixed limit\norder.amount \u003C 50000\n\n-- Under caller's personal limit\ntransfer.amount \u003C= participant.transferLimit\n",[205,742,740],{"__ignoreMap":320},[221,744,746],{"id":745},"status-filtering","Status Filtering",[312,748,751],{"className":749,"code":750,"language":317},[315],"-- Specific statuses\nentity.status in ['active', 'pending']\n\n-- Exclude archived\nentity.status != 'archived'\n\n-- Exclude soft-deleted\nnot entity.deleted == true\n",[205,752,750],{"__ignoreMap":320},[221,754,756],{"id":755},"combined-policies","Combined Policies",[312,758,761],{"className":759,"code":760,"language":317},[315],"-- Finance role with amount cap\nparticipant.roles contains 'finance' and order.amount \u003C 50000\n\n-- Admin or owner\nparticipant.roles contains 'admin' or entity.ownerId == participant.id\n\n-- Department match with classification restriction\nparticipant.department == entity.department\n    and entity.classification != 'top-secret'\n",[205,762,760],{"__ignoreMap":320},{"title":320,"searchDepth":764,"depth":764,"links":765},2,[766,767,773,776,780,781],{"id":199,"depth":764,"text":25},{"id":215,"depth":764,"text":216,"children":768},[769,771,772],{"id":223,"depth":770,"text":224},3,{"id":267,"depth":770,"text":268},{"id":309,"depth":770,"text":310},{"id":323,"depth":764,"text":324,"children":774},[775],{"id":493,"depth":770,"text":494},{"id":537,"depth":764,"text":538,"children":777},[778,779],{"id":556,"depth":770,"text":557},{"id":602,"depth":770,"text":310},{"id":611,"depth":764,"text":612},{"id":701,"depth":764,"text":702,"children":782},[783,784,785,786,787,788],{"id":705,"depth":770,"text":706},{"id":715,"depth":770,"text":716},{"id":725,"depth":770,"text":726},{"id":735,"depth":770,"text":736},{"id":745,"depth":770,"text":746},{"id":755,"depth":770,"text":756},"Complete reference for the ABAC policy expression language.","md",null,{},{"icon":180},{"title":177,"description":789},"2QwZ57SS9lwgYVQRj0ISWwpnr2TrNUW4y6C_dV4JVUY",[797,799],{"title":173,"path":174,"stem":175,"description":798,"icon":60,"children":-1},"Complete SQL grammar reference for migration scripts.",{"title":182,"path":183,"stem":184,"description":800,"icon":185,"children":-1},"Kinotic Resource Identifier specification.",1776066914365]