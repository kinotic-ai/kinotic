uage","3.reference\u002F3.abac-expression-language","i-lucide-file-code",{"title":182,"path":183,"stem":184,"icon":185},"CRI Format","\u002Freference\u002Fcri-format","3.reference\u002F4.cri-format","i-lucide-link",{"title":187,"path":188,"stem":189,"icon":190},"SDK Packages","\u002Freference\u002Fsdk-packages","3.reference\u002F5.sdk-packages","i-lucide-package",{"id":192,"title":173,"body":193,"description":1485,"extension":1486,"links":1487,"meta":1488,"navigation":1489,"path":174,"seo":1490,"stem":175,"__hash__":1491},"docs\u002F3.reference\u002F2.migration-sql-grammar.md",{"type":194,"value":195,"toc":1469},"minimark",[196,200,204,216,220,262,265,268,271,277,293,313,318,364,366,369,372,376,385,390,452,456,490,492,495,498,502,517,525,529,544,546,549,552,556,565,570,723,727,761,768,770,773,776,780,795,813,817,832,834,837,840,844,859,874,878,893,895,898,901,905,914,921,925,934,936,939,948,955,957,961,970,974,999,1023,1032,1036,1051,1053,1056,1306,1313,1315,1319,1357,1359,1363,1366,1465],[197,198,25],"h2",{"id":199},"overview",[201,202,203],"p",{},"This grammar reference applies to migration scripts used for schema and data migrations in Kinotic. Migration scripts use a SQL dialect designed for Elasticsearch index management and data operations.",[201,205,206,207,211,212,215],{},"All statements must end with a semicolon (",[208,209,210],"code",{},";","). Identifiers must start with a letter or underscore and can contain letters, numbers, and underscores. Strings are enclosed in single quotes (",[208,213,214],{},"'...'",").",[197,217,219],{"id":218},"statements-overview","Statements Overview",[221,222,223,229,234,239,244,249,254,259],"ul",{},[224,225,226],"li",{},[208,227,228],{},"CREATE TABLE",[224,230,231],{},[208,232,233],{},"CREATE COMPONENT TEMPLATE",[224,235,236],{},[208,237,238],{},"CREATE INDEX TEMPLATE",[224,240,241],{},[208,242,243],{},"REINDEX",[224,245,246],{},[208,247,248],{},"INSERT",[224,250,251],{},[208,252,253],{},"UPDATE",[224,255,256],{},[208,257,258],{},"DELETE",[224,260,261],{},"Comments",[263,264],"hr",{},[197,266,228],{"id":267},"create-table",[201,269,270],{},"Creates an Elasticsearch index with the specified field mappings.",[201,272,273],{},[274,275,276],"strong",{},"Syntax:",[278,279,284],"pre",{"className":280,"code":281,"language":282,"meta":283,"style":283},"language-sql shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","CREATE TABLE [IF NOT EXISTS] \u003Cindex_name> (\u003Ccolumn_name> \u003Ctype> [, \u003Ccolumn_name> \u003Ctype>]*) ;\n","sql","",[208,285,286],{"__ignoreMap":283},[287,288,291],"span",{"class":289,"line":290},"line",1,[287,292,281],{},[221,294,295,301],{},[224,296,297,300],{},[208,298,299],{},"IF NOT EXISTS"," (optional): Only create the index if it does not already exist.",[224,302,303,306,307,312],{},[208,304,305],{},"\u003Ctype>",": See ",[308,309,311],"a",{"href":310},"#supported-types","Supported Types",".",[201,314,315],{},[274,316,317],{},"Example:",[278,319,321],{"className":280,"code":320,"language":282,"meta":283,"style":283},"CREATE TABLE IF NOT EXISTS products (\n    name TEXT,\n    sku KEYWORD,\n    price DOUBLE,\n    inStock BOOLEAN,\n    createdAt DATE\n) ;\n",[208,322,323,328,334,340,346,352,358],{"__ignoreMap":283},[287,324,325],{"class":289,"line":290},[287,326,327],{},"CREATE TABLE IF NOT EXISTS products (\n",[287,329,331],{"class":289,"line":330},2,[287,332,333],{},"    name TEXT,\n",[287,335,337],{"class":289,"line":336},3,[287,338,339],{},"    sku KEYWORD,\n",[287,341,343],{"class":289,"line":342},4,[287,344,345],{},"    price DOUBLE,\n",[287,347,349],{"class":289,"line":348},5,[287,350,351],{},"    inStock BOOLEAN,\n",[287,353,355],{"class":289,"line":354},6,[287,356,357],{},"    createdAt DATE\n",[287,359,361],{"class":289,"line":360},7,[287,362,363],{},") ;\n",[263,365],{},[197,367,233],{"id":368},"create-component-template",[201,370,371],{},"Creates a reusable component template that can be referenced by index templates.",[201,373,374],{},[274,375,276],{},[278,377,379],{"className":280,"code":378,"language":282,"meta":283,"style":283},"CREATE COMPONENT TEMPLATE \u003Ctemplate_name> (\u003Cdefinition> [, \u003Cdefinition>]*) ;\n",[208,380,381],{"__ignoreMap":283},[287,382,383],{"class":289,"line":290},[287,384,378],{},[201,386,387],{},[274,388,389],{},"Definitions:",[391,392,393,409],"table",{},[394,395,396],"thead",{},[397,398,399,403,406],"tr",{},[400,401,402],"th",{},"Definition",[400,404,405],{},"Allowed Values",[400,407,408],{},"Description",[410,411,412,426,439],"tbody",{},[397,413,414,420,423],{},[415,416,417],"td",{},[208,418,419],{},"NUMBER_OF_SHARDS",[415,421,422],{},"Integer (e.g., 1, 3)",[415,424,425],{},"Number of primary shards for the index",[397,427,428,433,436],{},[415,429,430],{},[208,431,432],{},"NUMBER_OF_REPLICAS",[415,434,435],{},"Integer (e.g., 0, 1)",[415,437,438],{},"Number of replica shards for the index",[397,440,441,446,449],{},[415,442,443],{},[208,444,445],{},"\u003Ccolumn_name> \u003Ctype>",[415,447,448],{},"See Supported Types",[415,450,451],{},"Field mapping (name and type)",[201,453,454],{},[274,455,317],{},[278,457,459],{"className":280,"code":458,"language":282,"meta":283,"style":283},"CREATE COMPONENT TEMPLATE base_settings (\n    NUMBER_OF_SHARDS = 3,\n    NUMBER_OF_REPLICAS = 1,\n    createdAt DATE,\n    updatedAt DATE\n) ;\n",[208,460,461,466,471,476,481,486],{"__ignoreMap":283},[287,462,463],{"class":289,"line":290},[287,464,465],{},"CREATE COMPONENT TEMPLATE base_settings (\n",[287,467,468],{"class":289,"line":330},[287,469,470],{},"    NUMBER_OF_SHARDS = 3,\n",[287,472,473],{"class":289,"line":336},[287,474,475],{},"    NUMBER_OF_REPLICAS = 1,\n",[287,477,478],{"class":289,"line":342},[287,479,480],{},"    createdAt DATE,\n",[287,482,483],{"class":289,"line":348},[287,484,485],{},"    updatedAt DATE\n",[287,487,488],{"class":289,"line":354},[287,489,363],{},[263,491],{},[197,493,238],{"id":494},"create-index-template",[201,496,497],{},"Creates an index template that applies settings and mappings to indices matching a pattern.",[201,499,500],{},[274,501,276],{},[278,503,505],{"className":280,"code":504,"language":282,"meta":283,"style":283},"CREATE INDEX TEMPLATE \u003Ctemplate_name> FOR '\u003Cpattern>' USING '\u003Ccomponent_template>'\n    [WITH (\u003Cdefinition> [, \u003Cdefinition>]*)] ;\n",[208,506,507,512],{"__ignoreMap":283},[287,508,509],{"class":289,"line":290},[287,510,511],{},"CREATE INDEX TEMPLATE \u003Ctemplate_name> FOR '\u003Cpattern>' USING '\u003Ccomponent_template>'\n",[287,513,514],{"class":289,"line":330},[287,515,516],{},"    [WITH (\u003Cdefinition> [, \u003Cdefinition>]*)] ;\n",[221,518,519],{},[224,520,521,524],{},[208,522,523],{},"WITH (...)"," (optional): Additional definitions as in component templates.",[201,526,527],{},[274,528,317],{},[278,530,532],{"className":280,"code":531,"language":282,"meta":283,"style":283},"CREATE INDEX TEMPLATE logs_template FOR 'logs-*' USING 'base_settings'\n    WITH (NUMBER_OF_REPLICAS = 2, level KEYWORD) ;\n",[208,533,534,539],{"__ignoreMap":283},[287,535,536],{"class":289,"line":290},[287,537,538],{},"CREATE INDEX TEMPLATE logs_template FOR 'logs-*' USING 'base_settings'\n",[287,540,541],{"class":289,"line":330},[287,542,543],{},"    WITH (NUMBER_OF_REPLICAS = 2, level KEYWORD) ;\n",[263,545],{},[197,547,243],{"id":548},"reindex",[201,550,551],{},"Copies documents from one index to another with optional transformations.",[201,553,554],{},[274,555,276],{},[278,557,559],{"className":280,"code":558,"language":282,"meta":283,"style":283},"REINDEX \u003Csource_index> INTO \u003Cdest_index> [WITH (\u003Coption> [, \u003Coption>]*)] ;\n",[208,560,561],{"__ignoreMap":283},[287,562,563],{"class":289,"line":290},[287,564,558],{},[201,566,567],{},[274,568,569],{},"Options:",[391,571,572,583],{},[394,573,574],{},[397,575,576,579,581],{},[400,577,578],{},"Option",[400,580,405],{},[400,582,408],{},[410,584,585,604,617,633,646,663,676,689,707],{},[397,586,587,592,601],{},[415,588,589],{},[208,590,591],{},"CONFLICTS",[415,593,594,597,598],{},[208,595,596],{},"ABORT",", ",[208,599,600],{},"PROCEED",[415,602,603],{},"How to handle version conflicts: abort or proceed",[397,605,606,611,614],{},[415,607,608],{},[208,609,610],{},"MAX_DOCS",[415,612,613],{},"Integer (e.g., 1000)",[415,615,616],{},"Maximum number of documents to reindex",[397,618,619,624,630],{},[415,620,621],{},[208,622,623],{},"SLICES",[415,625,626,629],{},[208,627,628],{},"AUTO",", Integer (e.g., 2)",[415,631,632],{},"Number of slices (parallelism); AUTO lets Elasticsearch decide",[397,634,635,640,643],{},[415,636,637],{},[208,638,639],{},"SIZE",[415,641,642],{},"Integer (e.g., 500)",[415,644,645],{},"Batch size for reindexing",[397,647,648,653,660],{},[415,649,650],{},[208,651,652],{},"SOURCE_FIELDS",[415,654,655,656,659],{},"Comma-separated list (e.g., ",[208,657,658],{},"'field1,field2'",")",[415,661,662],{},"Restrict source fields to copy",[397,664,665,670,673],{},[415,666,667],{},[208,668,669],{},"QUERY",[415,671,672],{},"String (Lucene query syntax)",[415,674,675],{},"Query to filter source documents",[397,677,678,683,686],{},[415,679,680],{},[208,681,682],{},"SCRIPT",[415,684,685],{},"String (Painless script)",[415,687,688],{},"Script to transform documents during reindex",[397,690,691,696,704],{},[415,692,693],{},[208,694,695],{},"WAIT",[415,697,698,597,701],{},[208,699,700],{},"TRUE",[208,702,703],{},"FALSE",[415,705,706],{},"If TRUE, wait for completion; if FALSE, return task ID",[397,708,709,714,720],{},[415,710,711],{},[208,712,713],{},"SKIP_IF_NO_SOURCE",[415,715,716,597,718],{},[208,717,700],{},[208,719,703],{},[415,721,722],{},"If TRUE, skip if source index does not exist (default FALSE)",[201,724,725],{},[274,726,317],{},[278,728,730],{"className":280,"code":729,"language":282,"meta":283,"style":283},"REINDEX old_products INTO new_products WITH (\n    CONFLICTS = PROCEED,\n    SLICES = AUTO,\n    QUERY = 'status:active',\n    SKIP_IF_NO_SOU