 or ",[213,1458,1459],{},"metadata.source.region == 'us-east'",[229,1461,1462,1465,1466,602,1468,602,1470,1472],{},[279,1463,1464],{},"All comparisons are string-based."," Even numeric or date values stored inside a JSON field are compared as strings. Use ",[213,1467,1164],{},[213,1469,1194],{},[213,1471,1254],{},", etc. for fields that require numeric or range queries.",[229,1474,1475,1478],{},[279,1476,1477],{},"Dynamic nesting is supported."," The sub-field structure does not need to be declared in the schema — any JSON shape can be stored and its leaf values will be indexed automatically.",[206,1480,1481],{},[279,1482,322],{},[283,1484,1486],{"className":285,"code":1485,"language":287,"meta":288,"style":288},"CREATE TABLE events (\n    id      UUID,\n    ts      DATE,\n    payload JSON\n) ;\n",[213,1487,1488,1493,1498,1503,1508],{"__ignoreMap":288},[292,1489,1490],{"class":294,"line":295},[292,1491,1492],{},"CREATE TABLE events (\n",[292,1494,1495],{"class":294,"line":335},[292,1496,1497],{},"    id      UUID,\n",[292,1499,1500],{"class":294,"line":341},[292,1501,1502],{},"    ts      DATE,\n",[292,1504,1505],{"class":294,"line":347},[292,1506,1507],{},"    payload JSON\n",[292,1509,1510],{"class":294,"line":353},[292,1511,368],{},[206,1513,1514,1515,1518],{},"A record with ",[213,1516,1517],{},"payload = {\"source\": {\"region\": \"us-east\"}, \"retries\": 3}"," can then be filtered as:",[283,1520,1522],{"className":285,"code":1521,"language":287,"meta":288,"style":288},"WHERE payload.source.region == 'us-east'\n",[213,1523,1524],{"__ignoreMap":288},[292,1525,1526],{"class":294,"line":295},[292,1527,1521],{},[206,1529,1530,1531,1534,1535,1538,1539,317],{},"Note that ",[213,1532,1533],{},"retries"," would be compared as the string ",[213,1536,1537],{},"'3'",", not the number ",[213,1540,1541],{},"3",[206,1543,1544,1545,1547],{},"For ",[213,1546,1339],{},", the object is stored and returned in query results but none of its sub-fields can be queried.",[268,1549],{